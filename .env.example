# APEX Configuration

# Stage 1: Inference Runtime
STAGE1_PORT=3000
STAGE1_HOST=127.0.0.1

# Stage 2: Codebase Intelligence
STAGE2_PORT=3001
STAGE2_HOST=127.0.0.1

# Workspace to index
APEX_WORKSPACE=/workspace

# Model directory (Stage 1)
MODEL_DIR=/app/data/models

# llama-server binary path (auto-detected if not set)
# LLAMA_SERVER_PATH=/usr/local/bin/llama-server

# API URLs (for inter-service communication)
INFERENCE_API_URL=http://localhost:3000
INTELLIGENCE_API_URL=http://localhost:3001
